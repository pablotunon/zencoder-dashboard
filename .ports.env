# -----------------------------------------------------------------
# Port configuration for branch isolation.
# Generated by: scripts/setup-ports.sh
#
# Each branch gets a unique PORT_OFFSET (0, 100, 200, ...).
# All host-exposed ports are BASE + PORT_OFFSET.
# Do NOT edit the individual port values manually — run the script.
#
# To set up ports for a new branch:
#   ./scripts/setup-ports.sh
#
# To reset to default (offset 0):
#   ./scripts/setup-ports.sh --offset 0
# -----------------------------------------------------------------

PORT_OFFSET=100
COMPOSE_PROJECT_NAME=agenthub-user-authentication-fab0

# Host-exposed ports (base + offset)
HOST_PORT_NGINX=8180
HOST_PORT_REDIS=6479
HOST_PORT_POSTGRES=5532
HOST_PORT_CLICKHOUSE_HTTP=8223
HOST_PORT_CLICKHOUSE_NATIVE=9100
