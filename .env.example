# ---- Branch Port Isolation ----
# Run ./scripts/setup-ports.sh to auto-assign unique ports for this branch.
# See .env for the current port configuration (gitignored, auto-generated).
# PORT_OFFSET=0
# COMPOSE_PROJECT_NAME=agenthub
# HOST_PORT_NGINX=8080
# HOST_PORT_REDIS=6379
# HOST_PORT_POSTGRES=5432
