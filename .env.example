POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse_dev

# Redis
REDIS_HOST=redis
